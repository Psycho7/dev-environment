{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "showClearContextOnPlanAccept": true,
  "permissions": {
    "allow": [
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi status:*)",
      "Bash(dotnet add:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet clean:*)",
      "Bash(dotnet format:*)",
      "Bash(dotnet list:*)",
      "Bash(dotnet new:*)",
      "Bash(dotnet pack:*)",
      "Bash(dotnet publish:*)",
      "Bash(dotnet remove:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet run:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet tool:*)",
      "Bash(dotnet watch:*)",
      "Bash(echo:*)",
      "Bash(fd:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git remote:*)",
      "Bash(git show-ref:*)",
      "Bash(git stash list:*)",
      "Bash(git status:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "WebSearch"
    ],
    "ask": [
      "Bash(git clean:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(sudo:*)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "csharp-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "clangd-lsp@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "codex@openai-codex": false,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "chezmoi-cookbook": {
      "source": {
        "source": "github",
        "repo": "Psycho7/chezmoi-cookbook"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  }
}
